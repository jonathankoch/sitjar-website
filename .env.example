# Local development env for `netlify dev`. Copy this file to ".env" and fill in
# real values. Do NOT commit ".env" (it is gitignored). In production, set these
# in the Netlify UI: Site configuration → Environment variables.

# Shared passphrase guests type to reveal the map. Use something long.
DIRECTIONS_PASSWORD=change-me-to-a-long-passphrase

# Map target: either "lat,lng" (e.g. "42.1234,2.5678") or a full address string.
MASIA_QUERY=41.3874,2.1686

# Human-readable address shown above the map.
MASIA_ADDRESS=Mas Sitjar, Catalunya
